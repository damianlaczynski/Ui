{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc/app",
    "baseUrl": ".",
    "types": [],
    "composite": true,
    "paths": {
      "@scss/*": ["./src/scss/*"],
      "@core/*": ["./src/app/core/*"],
      "@features/*": ["./src/app/features/*"],
      "@shared/*": ["./src/app/shared/*"],
      "@showcase/*": ["./src/app/showcase/*"],
      "@layout/*": ["./src/app/layout/*"],
      "@styles/*": ["./src/styles/*"],
      "@environments/*": ["./src/environments/*"],
      "ui": ["../../packages/ui/src/public-api.ts"],
      "ui/ngx-translate": ["../../packages/ui/ngx-translate/public-api.ts"]
    }
  },
  "files": ["src/main.ts"],
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"]
}
