{
  "name": "laczynski-ui-monorepo",
  "version": "1.0.0",
  "description": "ui component library monorepo with demo application",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "docs:build": "node scripts/generate-showcase-llms.mjs",
    "icons:build": "node scripts/generate-icon-sprite.mjs",
    "start": "concurrently \"npm run build:lib:watch\" \"ng serve ui-showcase\"",
    "prestart": "npm run docs:build && npm run icons:build",
    "start:ui-showcase": "ng serve ui-showcase",
    "prestart:ui-showcase": "npm run docs:build && npm run icons:build",
    "build": "ng build ui-showcase",
    "prebuild": "npm run docs:build && npm run icons:build",
    "build:ui-showcase": "ng build ui-showcase",
    "prebuild:ui-showcase": "npm run docs:build && npm run icons:build",
    "build:gh-pages": "ng build ui-showcase --configuration=production --base-href=/",
    "prebuild:gh-pages": "npm run docs:build && npm run icons:build",
    "watch": "ng build ui-showcase --watch --configuration development",
    "prewatch": "npm run docs:build && npm run icons:build",
    "prebuild:lib": "npm run icons:build",
    "build:lib": "ng build ui",
    "prebuild:lib:watch": "npm run icons:build",
    "build:lib:watch": "ng build ui --watch",
    "test": "ng test ui",
    "test:ui-showcase": "ng test ui-showcase",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"apps/showcase/src\" \"packages/ui/src\"",
    "format:check": "prettier --check \"apps/showcase/src\" \"packages/ui/src\"",
    "test:coverage": "ng test ui --coverage --watch=false",
    "prepare": "husky",
    "precommit": "lint-staged",
    "publish:lib": "cd dist/ui && npm publish --access public",
    "publish:lib:patch": "cd packages/ui && npm version patch && cd ../.. && npm run build:lib && npm run publish:lib",
    "publish:lib:minor": "cd packages/ui && npm version minor && cd ../.. && npm run build:lib && npm run publish:lib",
    "publish:lib:major": "cd packages/ui && npm version major && cd ../.. && npm run build:lib && npm run publish:lib"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,html}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{scss,json}": "prettier --write"
  },
  "dependencies": {
    "@angular/animations": "^21.1.0",
    "@angular/cdk": "^21.1.0",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-browser-dynamic": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@fluentui/svg-icons": "^1.1.313",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.1.0",
    "@angular-eslint/eslint-plugin": "21.1.0",
    "@angular-eslint/eslint-plugin-template": "21.1.0",
    "@angular-eslint/schematics": "21.1.0",
    "@angular-eslint/template-parser": "21.1.0",
    "@angular/build": "^21.1.0",
    "@angular/cli": "^21.1.0",
    "@angular/compiler-cli": "^21.1.0",
    "@eslint/config-array": "^0.20.0",
    "@eslint/object-schema": "^2.0.0",
    "@types/prismjs": "^1.26.6",
    "@typescript-eslint/eslint-plugin": "8.51.0",
    "@typescript-eslint/parser": "8.51.0",
    "angular-eslint": "^21.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "lint-staged": "^15.4.3",
    "ng-packagr": "^21.1.0",
    "prettier": "^3.5.3",
    "typescript": "~5.9.3",
    "vitest": "^4.0.8"
  }
}
